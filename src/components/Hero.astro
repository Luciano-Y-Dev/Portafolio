---

---

<main>
  <section
    class="min-h-screen flex flex-col items-center justify-center sm:px-6 gap-16 md:gap-24 lg:gap-32"
  >
    <div class="text-center space-y-4">
      <h1
        class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-bold text-white tracking-tight m-6"
      >
        Hola, soy <span
          class="text-[#75A0B4] drop-shadow-[0_0_20px_rgba(96,165,250,0.5)]"
          >Luciano Yanes</span
        >
      </h1>
      <p
        class="text-xs sm:text-sm md:text-base lg:text-lg text-slate-400 uppercase tracking-[0.2em] sm:tracking-[0.3em] font-['Roboto_Mono']"
      >
        Desarrollador más enfocado a python, data science y soluciones reales
      </p>
    </div>

    <div
      class="w-full max-w-\[200px\] sm:max-w-\[280px\] md:max-w-\[350px\] lg:max-w-md transition-all duration-700 hover:scale-110 hover:rotate-2"
    >
      <img
        src="/Dev-logo2.svg"
        alt="Logo Luciano Yanes"
        class="w-full h-auto drop-shadow-[0_0_30px_rgba(96,165,250,0.4)] hover:drop-shadow-[0_0_50px_rgba(96,165,250,0.6)]"
      />
    </div>

    <a
      href="#proyectos"
      class="group relative overflow-hidden rounded-full bg-white/5 backdrop-blur-md border border-white/10 px-8 sm:px-12 py-3 sm:py-4 text-xs sm:text-sm font-bold text-blue-400 shadow-[0_0_20px_rgba(96,165,250,0.2)] hover:shadow-[0_0_40px_rgba(96,165,250,0.4)] hover:border-blue-500/50 transition-all duration-300 active:scale-95"
    >
      <span class="relative z-10">VER PROYECTOS</span>
      <button
        class="absolute inset-0 bg-linear-to-r from-blue-500/0 via-blue-500/20 to-blue-500/0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      >
      </button>
    </a>
  </section>
</main>
