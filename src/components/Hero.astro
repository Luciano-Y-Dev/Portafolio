---
---

<main>
  <section
    class="min-h-screen flex flex-col items-center justify-center sm:px-6 gap-16 md:gap-24 lg:gap-32"
  >
    <div class="text-center space-y-4">
      <h1
        class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-bold text-white tracking-tight m-6"
      >
        <span data-i18hero="title">Hola, soy</span> <span
          class="text-[#75A0B4] drop-shadow-[0_0_20px_rgba(96,165,250,0.5)]"
          >Luciano Yanes</span
        >
      </h1>
      <p
        data-i18hero="subtitle"
        class="text-xs sm:text-sm md:text-base lg:text-lg text-slate-400 uppercase tracking-[0.2em] sm:tracking-[0.3em] font-['Roboto_Mono']"
      >
        Desarrollador más enfocado a python, data science y soluciones reales
      </p>
    </div>

    <div
      class="w-40 sm:w-56 md:w-72 lg:max-w-md transition-all duration-700 hover:scale-110 hover:rotate-2"
    >
      <img
        src="/Dev-logo2.svg"
        alt="Logo Luciano Yanes"
        class="w-full h-auto drop-shadow-[0_0_30px_rgba(96,165,250,0.4)] hover:drop-shadow-[0_0_50px_rgba(96,165,250,0.6)]"
      />
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="#proyectos"
        class="group relative overflow-hidden rounded-full bg-white/5 backdrop-blur-md border border-white/10 px-8 sm:px-12 py-3 sm:py-4 text-xs sm:text-sm font-bold text-[#abd6e9] hover:shadow-[0_0_20px_rgba(96,165,250,0.2)] hover:border-[#abd6e9c0] transition-all duration-300 active:scale-95"
      >
        <span data-i18hero="cta" class="relative z-10">VER PROYECTOS</span>
      </a>

      <a
        href="/CV_Luciano_Yanes.pdf"
        download="CV_Luciano_Yanes.pdf"
        class="group relative overflow-hidden rounded-full bg-white/5 backdrop-blur-md border border-white/10 px-8 sm:px-12 py-3 sm:py-4 text-xs sm:text-sm font-bold text-white/70 hover:text-white hover:shadow-[0_0_20px_rgba(96,165,250,0.2)] hover:border-white/30 transition-all duration-300"
        aria-label="Descargar CV"
      >
        <span data-i18hero="downloadCV" class="relative z-10">DESCARGAR CV</span>
      </a>
    </div>
  </section>
</main>