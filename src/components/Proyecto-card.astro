---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
  image: string;
}

const { title, description, tags, link, image } = Astro.props as Props;
---

<article
  class="group relative bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-[#75A0B4] transition-all"
>
  <div class="relative h-48 w-full">
    <img src={image} alt={title} class="w-full h-full object-cover" />
    <div
      class="absolute inset-0 bg-linear-to-t from-slate-900 via-slate-900/40 to-transparent"
    >
    </div>
  </div>

  <div class="p-6">
    <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-slate-400 text-sm mb-4 leading-relaxed font-['Roboto_Mono']">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-4">
      {
        tags.map((tag) => (
          <span class="text-[10px] uppercase tracking-wider bg-slate-800 text-[#75A0B4] px-2 py-1 rounded">
            {tag}
          </span>
        ))
      }
    </div>

    <a
      href={link}
      class="text-white text-sm font-bold border-b border-[#75A0B4] hover:text-[#75A0B4] transition-colors"
    >
      Ver Proyecto →
    </a>
  </div>
</article>
