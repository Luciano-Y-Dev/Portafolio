---
interface Props {
  title: string;
  description: string;
  tags: string[];
  link: string;
  image: string;
  t?: {
    projects: {
      viewProject: string;
    };
  };
}

const { title, description, tags, link, image, t } = Astro.props as Props;
---

<article
  class="group relative bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-[#75A0B4] transition-all"
>
  <div class="relative h-40 sm:h-48 w-full">
    <img src={image} alt={title} class="w-full h-full object-cover" />
    <div
      class="absolute inset-0 bg-linear-to-t from-slate-900 via-slate-900/40 to-transparent"
    >
    </div>
  </div>

  <div class="p-4 sm:p-6">
    <h3 class="text-lg sm:text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-slate-400 text-sm mb-3 sm:mb-4 leading-relaxed font-['Roboto_Mono']">
      {description}
    </p>

    <div class="flex flex-wrap gap-2 mb-3 sm:mb-4">
      {
        tags.map((tag) => (
          <span class="text-[10px] uppercase tracking-wider bg-slate-800 text-[#75A0B4] px-2 py-1 rounded">
            {tag}
          </span>
        ))
      }
    </div>

    <a
      href={link}
      class="inline-flex items-center gap-2 text-white text-sm font-bold py-2 px-1 -ml-1 rounded hover:bg-white/5 transition-colors"
    >
      {t?.projects?.viewProject || 'Ver Proyecto'} <span class="text-[#75A0B4]">→</span>
    </a>
  </div>
</article>