---
---

<style>
  .hamburger-line {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .menu-open .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 6px);
  }
  .menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-open .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -6px);
  }
</style>

<nav
  class="flex justify-between items-center w-full px-4 sm:px-6 md:px-8 py-4 bg-[#0f101f55]/80 backdrop-blur-sm fixed z-50"
>
  <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
    <a href="/" class="p-2 -ml-2">
      <img
        src="Black-Hole.webp"
        alt="Logo"
        class="aspect-square size-10 sm:size-12 object-cover drop-shadow-[0_0_30px_rgba(96,165,250,0.4)]"
      />
    </a>

    <button
      id="menu-toggle"
      class="md:hidden p-2 text-white/70 hover:text-blue-400 transition-colors"
      aria-label="Menú"
    >
      <div class="w-6 h-5 flex flex-col justify-between cursor-pointer">
        <span class="hamburger-line h-0.5 w-full bg-current rounded"></span>
        <span class="hamburger-line h-0.5 w-full bg-current rounded"></span>
        <span class="hamburger-line h-0.5 w-full bg-current rounded"></span>
      </div>
    </button>

    <ul
      id="mobile-menu"
      class="md:flex list-none gap-4 sm:gap-6 hidden fixed md:relative top-full left-0 right-0 bg-[#0f101f]/95 md:bg-transparent backdrop-blur-md md:backdrop-blur-none flex-col md:flex-row items-center justify-center md:justify-end py-6 md:py-0 border-t md:border-t-0 border-white/10"
    >
      <li>
        <a href="#sobre-mi" data-i18nav="about" class="text-sm text-white/70 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all px-3 py-2 block">
          Sobre mí
        </a>
      </li>

      <li>
        <a href="#skills" data-i18nav="skills" class="text-sm text-white/70 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all px-3 py-2 block">
          Skills
        </a>
      </li>

      <li>
        <a href="#proyectos" data-i18nav="projects" class="text-sm text-white/70 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all px-3 py-2 block">
          Proyectos
        </a>
      </li>

      <li>
        <a
          href="#contacto"
          data-i18nav="contact"
          class="text-sm text-white/70 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all px-3 py-2 block"
        >
          Contacto
        </a>
      </li>

      <li>
        <button
          id="lang-toggle"
          class="text-sm text-white/70 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all px-3 py-2"
          aria-label="Cambiar idioma"
        >
          EN
        </button>
      </li>
    </ul>
  </div>
</nav>

<script>
  import { initI18n, setLang, getCurrentLang } from "../i18/client.js";

  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuLinks = mobileMenu?.querySelectorAll('a');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuToggle?.classList.toggle('menu-open');
  });

  menuLinks?.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuToggle?.classList.remove('menu-open');
    });
  });

  const langToggle = document.getElementById('lang-toggle');
  langToggle?.addEventListener('click', () => {
    const currentLang = getCurrentLang();
    const newLang = currentLang === 'es' ? 'en' : 'es';
    setLang(newLang);
  });

  document.addEventListener('DOMContentLoaded', initI18n);
</script>