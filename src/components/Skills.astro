---

---

<section
  id="skills"
  class="min-h-screen flex flex-col items-center justify-center px-4 sm:px-6 lg:px-8 py-20"
>
  <h2
    class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tighter italic uppercase text-center"
  >
    Skills
  </h2>

  <!-- Python y Data Science -->
  <div class="w-full max-w-2xl mb-8">
    <h3 class="text-xl font-bold text-[#75A0B4] mb-4 uppercase tracking-wider">
      Python y Data Science
    </h3>
    <div class="flex flex-wrap gap-3">
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >Python</span
      >
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >Pandas</span
      >
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >NumPy</span
      >
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >Scikit-learn</span
      >
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >Matplotlib</span
      >
      <span
        class="px-4 py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white"
        >Seaborn</span
      >
    </div>
  </div>

  <!-- Frontend -->
  <div class="w-full max-w-2xl mb-8">
    <h3
      class="text-lg font-bold text-[#75A0B4]/70 mb-4 uppercase tracking-wider"
    >
      Frontend y UI
    </h3>
    <div class="flex flex-wrap gap-3">
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Astro</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Reflex</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Tailwind CSS</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Streamlit</span
      >
    </div>
  </div>

  <!-- Backend -->
  <div class="w-full max-w-2xl mb-12">
    <h3
      class="text-lg font-bold text-[#75A0B4]/70 mb-4 uppercase tracking-wider"
    >
      Backend y Deployment
    </h3>
    <div class="flex flex-wrap gap-3">
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Vercel</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >APIs REST</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >SQL</span
      >
      <span
        class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300"
        >Integración de datos</span
      >
    </div>
  </div>

  <!-- Extra: Idioma, Estudios, Habilidades -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-4xl">
    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
      <h3
        class="text-lg font-bold text-[#75A0B4] mb-4 uppercase tracking-wider"
      >
        Idioma
      </h3>
      <div class="space-y-2">
        <span
          class="block px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white"
          >Inglés B1-B2</span
        >
        <span class="block text-xs text-slate-500">6 meses en Londres</span>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
      <h3
        class="text-lg font-bold text-[#75A0B4] mb-4 uppercase tracking-wider"
      >
        Estudios
      </h3>
      <div class="space-y-2">
        <span
          class="block px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white"
          >Ing. de Sistemas</span
        >
        <span class="block text-xs text-slate-500">En curso</span>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-6">
      <h3
        class="text-lg font-bold text-[#75A0B4] mb-4 uppercase tracking-wider"
      >
        Habilidades
      </h3>
      <div class="flex flex-wrap gap-2">
        <span
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Resolución de problemas</span
        >
        <span
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Aprendizaje continuo</span
        >
        <span
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Comunicar de forma sencilla</span
        >
        <span
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Trabajo en equipo</span
        >
        <span
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Autodidacta</span
        >
      </div>
    </div>
  </div>
</section>
