---
---

<section
  id="skills"
  class="min-h-screen flex flex-col items-center justify-center px-6 sm:px-6 lg:px-8 py-12 sm:py-20"
>
  <h2
    data-i18skills="title"
    class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-8 sm:mb-6 tracking-tighter italic uppercase text-center"
  >
    Skills
  </h2>

  <div class="w-full max-w-2xl mb-6 sm:mb-8 px-2 sm:px-0">
    <h3 data-i18skills="pythonData" class="text-lg sm:text-2xl font-bold text-[#75A0B4] mb-3 sm:mb-4 uppercase tracking-wider">
      Python y Data Science
    </h3>
    <div class="flex flex-wrap gap-2 sm:gap-3">
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >Python</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >Pandas</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >NumPy</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >Scikit-learn</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >Matplotlib</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-[#75A0B4]/10 border border-[#75A0B4]/30 rounded-lg text-white text-xs sm:text-sm"
        >Seaborn</span
      >
    </div>
  </div>

  <div class="w-full max-w-2xl mb-6 sm:mb-8 px-2 sm:px-0">
    <h3
      data-i18skills="frontend"
      class="text-base sm:text-lg font-bold text-[#75A0B4]/70 mb-3 sm:mb-4 uppercase tracking-wider"
    >
      Frontend y UI
    </h3>
    <div class="flex flex-wrap gap-2 sm:gap-3">
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Astro</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Reflex</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Tailwind CSS</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Streamlit</span
      >
    </div>
  </div>

  <div class="w-full max-w-2xl mb-8 sm:mb-12 px-2 sm:px-0">
    <h3
      data-i18skills="backend"
      class="text-base sm:text-lg font-bold text-[#75A0B4]/70 mb-3 sm:mb-4 uppercase tracking-wider"
    >
      Backend y Deployment
    </h3>
    <div class="flex flex-wrap gap-2 sm:gap-3">
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Vercel</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >APIs REST</span
      >
      <span
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >SQL</span
      >
      <span
        data-i18skills="dataIntegration"
        class="px-3 py-1.5 sm:px-4 sm:py-2 bg-white/5 border border-white/10 rounded-lg text-slate-300 text-xs sm:text-sm"
        >Integración de datos</span
      >
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 w-full max-w-4xl">
    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-4 sm:p-6">
      <h3
        data-i18skills="language"
        class="text-base sm:text-lg font-bold text-[#75A0B4] mb-3 sm:mb-4 uppercase tracking-wider"
      >
        Idioma
      </h3>
      <div class="space-y-2">
        <span
          data-i18skills="englishLevel"
          class="block px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-sm"
          >Inglés B1-B2</span
        >
        <span data-i18skills="studyTime" class="block text-xs text-slate-500">6 meses en Londres</span>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-4 sm:p-6">
      <h3
        data-i18skills="studies"
        class="text-base sm:text-lg font-bold text-[#75A0B4] mb-3 sm:mb-4 uppercase tracking-wider"
      >
        Estudios
      </h3>
      <div class="space-y-2">
        <span
          data-i18skills="career"
          class="block px-3 py-2 bg-white/5 border border-white/10 rounded-lg text-white text-sm"
          >Ing. de Sistemas</span
        >
        <span data-i18skills="inProgress" class="block text-xs text-slate-500">En curso</span>
      </div>
    </div>

    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-4 sm:p-6">
      <h3
        data-i18skills="abilities"
        class="text-base sm:text-lg font-bold text-[#75A0B4] mb-3 sm:mb-4 uppercase tracking-wider"
      >
        Habilidades
      </h3>
      <div class="flex flex-wrap gap-2">
        <span
          data-i18skills="problemSolving"
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Resolución de problemas</span
        >
        <span
          data-i18skills="continuousLearning"
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Aprendizaje continuo</span
        >
        <span
          data-i18skills="communicate"
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Comunicar de forma sencilla</span
        >
        <span
          data-i18skills="teamwork"
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Trabajo en equipo</span
        >
        <span
          data-i18skills="selfTaught"
          class="px-2 py-1 bg-white/5 border border-white/10 rounded text-xs text-slate-300"
          >Autodidacta</span
        >
      </div>
    </div>
  </div>
</section>